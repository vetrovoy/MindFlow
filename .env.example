# ─────────────────────────────────────────────────────────────────────────────
# MindFlow Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# This file is used by:
# - Docker compose: reads and passes to containers
# - Local dev: copy values to apps/server/.env and apps/web/.env
#
# Usage:
#   cp .env.example .env
#   (edit .env with your values)
#   docker compose up -d  # or pnpm dev:web
#

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# Local development: postgresql://mindflow:mindflow@localhost:5432/mindflow
# Docker: postgresql://mindflow:mindflow@postgres:5432/mindflow
#
# The DB_PASSWORD is also used as POSTGRES_PASSWORD in docker-compose
DATABASE_URL=postgresql://mindflow:mindflow@localhost:5432/mindflow
DB_PASSWORD=mindflow

# ─────────────────────────────────────────────────────────────────────────────
# Server (API)
# ─────────────────────────────────────────────────────────────────────────────

# Port for server (default: 3000)
SERVER_PORT=3000

# JWT secret for token signing (min 32 chars — change in production!)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-must-be-at-least-32-characters-long

# Allowed origins for CORS (comma-separated)
# Local: http://localhost,http://localhost:4174,http://localhost:80
# Docker: http://localhost,http://localhost:80
ALLOWED_ORIGINS=http://localhost,http://localhost:4174

# ─────────────────────────────────────────────────────────────────────────────
# Web (Frontend)
# ─────────────────────────────────────────────────────────────────────────────

# API base URL for web frontend
# Local dev: http://localhost:3000
# Docker/production: (empty string) — uses nginx proxy on /api/
VITE_API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────────────────────────

# dev, staging, production
NODE_ENV=development
