# Web Frontend Environment Variables
# For development: leave empty (uses Vite proxy that rewrites /api to http://localhost:3000)
# For production: set to the actual API server URL (e.g. https://api.example.com)
VITE_API_BASE_URL=

# Set to "true" to force local-only mode (no backend server)
# VITE_DISABLE_BACKEND=true
