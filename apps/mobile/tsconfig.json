{
  "extends": "../../packages/config/tsconfig/react-native.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods", "**/android", "**/ios"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mindflow/domain": ["../../packages/domain/src/index.ts"],
      "@mindflow/data": ["../../packages/data/src/index.ts"],
      "@mindflow/data/sqlite": ["../../packages/data/src/sqlite/repository.ts"],
      "@mindflow/ui": ["../../packages/ui/src/index.ts"],
      "@mindflow/copy": ["../../packages/copy/src/index.ts"],
      "@mobile/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@pages/*": ["src/pages/*"],
      "@entities/*": ["src/entities/*"],
      "@features/*": ["src/features/*"],
      "@widgets/*": ["src/widgets/*"],
      "@app/*": ["src/app/*"]
    }
  }
}
