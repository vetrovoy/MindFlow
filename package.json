{
  "name": "mindflow-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-test-renderer": "19.2.3",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf .turbo packages/*/.turbo apps/*/.turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "server:dev": "pnpm --filter @mindflow/server dev",
    "server:build": "pnpm --filter @mindflow/server build",
    "server:start": "pnpm --filter @mindflow/server start",
    "server:test": "pnpm --filter @mindflow/server test",
    "server:typecheck": "pnpm --filter @mindflow/server typecheck",
    "web:dev": "pnpm --filter @mindflow/web dev",
    "web:build": "pnpm --filter @mindflow/web build",
    "web:test": "pnpm --filter @mindflow/web test",
    "web:typecheck": "pnpm --filter @mindflow/web typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down postgres",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
