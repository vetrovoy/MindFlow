{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@mindflow/copy": ["./packages/copy/src/index.ts"],
      "@mindflow/domain": ["./packages/domain/src/index.ts"],
      "@mindflow/data": ["./packages/data/src/index.ts"],
      "@mindflow/data/sqlite": ["./packages/data/src/sqlite/repository.ts"],
      "@mindflow/ui": ["./packages/ui/src/index.ts"],
      "@mindflow/config/*": ["./packages/config/*"]
    }
  }
}
